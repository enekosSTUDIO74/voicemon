      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.85 }
            ]
          }
        }
      }
    },
    {
      "title": "🔧 Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "MOS Score",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(voicemon_mos_score)",
          "legendFormat": "MOS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 1, "max": 5,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3.0 },
              { "color": "yellow", "value": 3.5 },
              { "color": "green", "value": 4.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Task Resolution",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 32 },
