        },
        {
          "expr": "histogram_quantile(0.95, rate(voicemon_llm_ttft_ms_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(voicemon_llm_ttft_ms_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
