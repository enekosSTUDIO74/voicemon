        {
          "expr": "rate(voicemon_stt_latency_ms_sum[5m]) / rate(voicemon_stt_latency_ms_count[5m])",
          "legendFormat": "STT Avg",
          "refId": "A"
        },
        {
          "expr": "rate(voicemon_llm_ttft_ms_sum[5m]) / rate(voicemon_llm_ttft_ms_count[5m])",
