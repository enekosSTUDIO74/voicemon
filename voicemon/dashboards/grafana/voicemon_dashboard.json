        {
          "expr": "sum by (resolution_type) (voicemon_tasks_resolved_total)",
          "legendFormat": "{{resolution_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tool Calls by Function",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (function_name) (rate(voicemon_tool_calls_total[1h])) * 3600",
