  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["voicemon", "voice-ai", "observability"],
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(voicemon_sessions_total, agent_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "VoiceMon — Voice AI Observability",
  "uid": "voicemon-main",
  "version": 1
