      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(voicemon_llm_tokens_total{direction=\"input\"}[5m])) * 60",
          "legendFormat": "Input Tokens/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(voicemon_llm_tokens_total{direction=\"output\"}[5m])) * 60",
          "legendFormat": "Output Tokens/min",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "STT Confidence Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(voicemon_stt_confidence_bucket[5m]))",
          "legendFormat": "P50 Confidence",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.05, rate(voicemon_stt_confidence_bucket[5m]))",
